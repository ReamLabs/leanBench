{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "lean-bench run record (v1)",
  "description": "One per benchmark run on a target machine. Additive-only evolution: later schema versions may add fields but must not remove or repurpose existing ones. The site always branches on `schema_version`.",
  "type": "object",
  "required": ["schema_version", "run_id", "timestamp", "machine", "workloads"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "run_id": { "type": "string", "description": "Unique id: <ISO timestamp>__<fingerprint>" },
    "timestamp": { "type": "string", "format": "date-time" },
    "machine": {
      "type": "object",
      "required": ["fingerprint", "cpu_model", "cpu_arch", "physical_cores", "logical_cores", "memory_gb", "os", "label"],
      "properties": {
        "fingerprint":     { "type": "string", "description": "Short hash identifying this machine across runs" },
        "label":           { "type": "string", "description": "Human-readable nickname for this host" },
        "cpu_model":       { "type": "string" },
        "cpu_arch":        { "type": "string" },
        "physical_cores":  { "type": "integer" },
        "logical_cores":   { "type": "integer" },
        "memory_gb":       { "type": "number" },
        "os":              { "type": "string" },
        "kernel":          { "type": "string" }
      }
    },
    "toolchain": {
      "type": "object",
      "properties": {
        "rustc":    { "type": "string" },
        "git_shas": {
          "type": "object",
          "properties": {
            "leansig_sha":      { "type": "string" },
            "leanmultisig_sha": { "type": "string" }
          }
        }
      }
    },
    "workloads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "unit", "timing"],
        "properties": {
          "name":       { "type": "string" },
          "unit":       { "type": "string", "enum": ["ns"] },
          "samples_ns": { "type": "array", "items": { "type": "integer" } },
          "timing": {
            "type": "object",
            "required": ["n", "mean_ns", "min_ns", "max_ns"],
            "properties": {
              "n":         { "type": "integer" },
              "mean_ns":   { "type": "integer" },
              "stddev_ns": { "type": "integer" },
              "min_ns":    { "type": "integer" },
              "p50_ns":    { "type": "integer" },
              "p95_ns":    { "type": "integer" },
              "max_ns":    { "type": "integer" }
            }
          },
          "resources": {
            "type": "object",
            "properties": {
              "cpu_percent":  { "type": ["object", "null"] },
              "rss_bytes":    { "type": ["object", "null"] },
              "n_samples":    { "type": "integer" },
              "interval_ms":  { "type": "integer" }
            }
          },
          "meta": { "type": "object" }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
